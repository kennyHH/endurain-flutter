# Copy this file to android/key.properties and fill it locally.
# Never commit android/key.properties or keystore files.
# CI can provide the same values with these environment variables:
# ANDROID_KEYSTORE_PATH, ANDROID_KEYSTORE_PASSWORD, ANDROID_KEY_ALIAS,
# ANDROID_KEY_PASSWORD

storeFile=/absolute/path/to/upload-keystore.jks
storePassword=replace-with-keystore-password
keyAlias=replace-with-key-alias
keyPassword=replace-with-key-password

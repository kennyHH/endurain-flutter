{
  "extends": [
    "config:recommended"
  ],
  "timezone": "Etc/UTC",
  "labels": [
    "dependencies"
  ],
  "osvVulnerabilityAlerts": true,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 10,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 4am on monday"
    ]
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "non-major dependency updates"
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "dependencies",
        "major-update"
      ]
    }
  ]
}